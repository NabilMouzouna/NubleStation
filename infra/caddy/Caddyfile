{
    # Disable HTTPS for now — we're on HTTP for LAN simplicity
    auto_https off
}

# Console — admin dashboard (Next.js standalone)
console.{$ORG_NAME}.local:80 {
    reverse_proxy console:3000
    log {
        output stdout
    }
}

# API — single entry for all backend services (Gateway)
api.{$ORG_NAME}.local:80 {
    reverse_proxy api:3000
    log {
        output stdout
    }
}

# Deployed app frontends — served from /var/nuble/apps/{appname}/current/
# {labels.1} extracts the first subdomain label (e.g. "tasks" from tasks.nuble.local)
*.{$ORG_NAME}.local:80 {
    @notReserved {
        not host console.{$ORG_NAME}.local api.{$ORG_NAME}.local
    }
    handle @notReserved {
        root * /var/nuble/apps/{labels.1}/current
        file_server
        try_files {path} /index.html
        log {
            output stdout
        }
    }
}