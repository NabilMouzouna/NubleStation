# Organization identity
ORG_NAME=nuble
ADMIN_PASSWORD=changeme

# Network
HOST_IP=192.168.1.100

# Postgres
POSTGRES_USER=nuble
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nuble

# Derived from Postgres vars — auto-generated by install.sh
DATABASE_URL=postgres://nuble:changeme@postgres:5432/nuble

# HMAC secret shared between Gateway and internal services (min 32 chars)
# Auto-generated by install.sh via: openssl rand -hex 32
INTERNAL_HMAC_SECRET=change-me-use-openssl-rand-hex-32
