---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Sidebar from '../components/Sidebar.astro';
import TOC from '../components/TOC.astro';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
}
const { title, description, headings = [] } = Astro.props;
---
<Base title={title} description={description}>
  <Nav />

  <div class="pt-14 flex min-h-screen max-w-screen-2xl mx-auto">
    <!-- Sidebar -->
    <aside
      class="hidden md:flex flex-col fixed top-14 bottom-0 overflow-y-auto z-30"
      style="width:var(--sidebar-width);border-right:1px solid var(--border);background:var(--bg);">
      <Sidebar />
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0" id="main-content">
      <div class="flex">
        <!-- Spacer for sidebar on md+ -->
        <div class="hidden md:block flex-shrink-0" style="width:var(--sidebar-width)"></div>

        <!-- Article -->
        <article class="flex-1 min-w-0 px-6 md:px-10 lg:px-16 py-10 pb-20">
          <div class="prose max-w-3xl mx-auto xl:max-w-none">
            <slot />
          </div>

          <!-- Footer link -->
          <div class="mt-16 pt-6 flex justify-between gap-4 text-sm max-w-3xl mx-auto" style="border-top:1px solid var(--border)">
            <span></span>
            <a href="https://github.com/NabilMouzouna/NubleStation/issues"
               target="_blank" rel="noopener"
               class="flex items-center gap-1.5 transition-colors"
               style="color:var(--text-muted)"
               onmouseover="this.style.color='var(--text)'"
               onmouseout="this.style.color='var(--text-muted)'">
              Edit on GitHub →
            </a>
          </div>
        </article>

        <!-- TOC -->
        <div class="hidden xl:block flex-shrink-0" style="width:var(--toc-width)">
          <TOC headings={headings} />
        </div>
      </div>
    </main>
  </div>

  <!-- Mobile sidebar toggle -->
  <button
    id="mobile-menu-btn"
    class="md:hidden fixed bottom-5 right-5 z-50 w-12 h-12 rounded-full shadow-lg flex items-center justify-center"
    style="background:var(--accent);color:white;"
    aria-label="Toggle menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <!-- Mobile sidebar overlay -->
  <div id="mobile-overlay" class="md:hidden fixed inset-0 z-40 hidden" style="background:rgba(0,0,0,0.5)">
    <aside class="fixed top-0 left-0 bottom-0 overflow-y-auto w-72 shadow-2xl" style="background:var(--bg)">
      <div class="flex items-center justify-between p-4 border-b" style="border-color:var(--border)">
        <span class="font-semibold text-sm" style="color:var(--text)">Navigation</span>
        <button id="mobile-close" style="color:var(--text-muted)">✕</button>
      </div>
      <Sidebar />
    </aside>
  </div>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const overlay = document.getElementById('mobile-overlay');
    const closeBtn = document.getElementById('mobile-close');
    btn?.addEventListener('click', () => overlay?.classList.toggle('hidden'));
    closeBtn?.addEventListener('click', () => overlay?.classList.add('hidden'));
    overlay?.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.add('hidden'); });

    // Inject copy buttons into every code block
    document.querySelectorAll('.prose pre').forEach((pre) => {
      const copyBtn = document.createElement('button');
      copyBtn.className = 'copy-btn';
      copyBtn.textContent = 'Copy';
      pre.appendChild(copyBtn);
      copyBtn.addEventListener('click', async () => {
        const text = (pre.querySelector('code') as HTMLElement)?.innerText ?? (pre as HTMLElement).innerText;
        try {
          await navigator.clipboard.writeText(text);
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.add('copied');
        } catch {
          copyBtn.textContent = 'Failed';
        }
        setTimeout(() => { copyBtn.textContent = 'Copy'; copyBtn.classList.remove('copied'); }, 2000);
      });
    });
  </script>
</Base>
