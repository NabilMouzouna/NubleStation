---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="NubleStation" description="Self-hosted backend infrastructure for small organizations. One command turns any Linux machine into a private cloud.">

  <!-- Nav -->
  <header class="fixed top-0 left-0 right-0 z-50 h-14 border-b" style="background:var(--bg);border-color:var(--border);backdrop-filter:blur(12px);">
    <div class="flex items-center justify-between h-full px-5 max-w-6xl mx-auto">
      <a href={base} class="flex items-center gap-2.5">
        <img src={`${base}icon.svg`} alt="NubleStation" class="h-7 w-auto" />
        <span class="font-semibold text-sm tracking-tight" style="color:var(--text)">NubleStation</span>
      </a>
      <div class="flex items-center gap-1">
        <a href={`${base}docs/getting-started/introduction`}
           class="hidden sm:flex items-center text-sm px-3 py-1.5 rounded-md transition-colors font-medium"
           style="color:var(--text-muted)"
           onmouseover="this.style.background='var(--surface-raised)';this.style.color='var(--text)'"
           onmouseout="this.style.background='';this.style.color='var(--text-muted)'">
          Docs
        </a>
        <a href="https://github.com/NabilMouzouna/NubleStation" target="_blank" rel="noopener"
           class="flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-md transition-colors"
           style="color:var(--text-muted)"
           onmouseover="this.style.background='var(--surface-raised)';this.style.color='var(--text)'"
           onmouseout="this.style.background='';this.style.color='var(--text-muted)'">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
        <button id="theme-toggle"
                class="flex items-center justify-center w-9 h-9 rounded-md transition-colors"
                style="color:var(--text-muted)"
                onmouseover="this.style.background='var(--surface-raised)';this.style.color='var(--text)'"
                onmouseout="this.style.background='';this.style.color='var(--text-muted)'"
                aria-label="Toggle theme">
          <svg id="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden dark:block">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg id="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="block dark:hidden">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main>

    <!-- ── Hero ───────────────────────────────────────────────────────── -->
    <section class="hero relative pt-32 pb-24 px-5 overflow-hidden">
      <!-- Background dot grid -->
      <div class="dot-grid" aria-hidden="true"></div>
      <!-- Radial glow -->
      <div class="glow" aria-hidden="true"></div>

      <div class="max-w-4xl mx-auto text-center relative z-10">
        <!-- Eyebrow badge -->
        <div class="inline-flex items-center gap-2 mb-8 px-3.5 py-1.5 rounded-full text-xs font-medium border"
             style="border-color:var(--border);background:var(--surface);color:var(--text-muted)">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse flex-shrink-0"></span>
          Self-hosted · LAN-native · No cloud required
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] mb-6" style="color:var(--text)">
          Your clinic's own<br/>
          <span class="grad-text">private cloud.</span>
        </h1>

        <!-- Tagline -->
        <p class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-10" style="color:var(--text-muted)">
          NubleStation turns any Linux machine into a complete backend platform —
          auth, database, storage, and frontend hosting — accessible from every
          device on the network via friendly subdomains.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href={`${base}docs/getting-started/installation`}
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm text-white transition-all duration-150 shadow-lg hover:shadow-violet-500/25"
             style="background:var(--accent);"
             onmouseover="this.style.background='var(--accent-hover)';this.style.transform='translateY(-1px)'"
             onmouseout="this.style.background='var(--accent)';this.style.transform=''">
            Get started
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
          <a href="https://github.com/NabilMouzouna/NubleStation" target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm border transition-all duration-150"
             style="border-color:var(--border);color:var(--text);background:var(--surface)"
             onmouseover="this.style.background='var(--surface-raised)';this.style.transform='translateY(-1px)'"
             onmouseout="this.style.background='var(--surface)';this.style.transform=''">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            GitHub
          </a>
        </div>

        <!-- Install command -->
        <div class="mt-12 mx-auto max-w-2xl">
          <div class="terminal-card rounded-xl overflow-hidden border text-left shadow-2xl"
               style="border-color:var(--border);background:var(--code-bg)">
            <div class="flex items-center gap-1.5 px-4 py-3 border-b" style="border-color:var(--border)">
              <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
              <span class="ml-2 text-xs font-mono" style="color:var(--text-muted)">bash</span>
            </div>
            <div class="px-5 py-4 font-mono text-sm leading-relaxed">
              <div class="flex items-start gap-2 mb-3">
                <span style="color:#a78bfa">$</span>
                <span style="color:var(--text)">curl -sSL https://github.com/NabilMouzouna/NubleStation/releases/latest/download/install.sh | bash</span>
              </div>
              <div class="mt-1 space-y-1 text-xs" style="color:var(--text-muted)">
                <div><span style="color:#4ade80">✓</span> Docker detected</div>
                <div><span style="color:#4ade80">✓</span> Host IP: 192.168.1.100</div>
                <div><span style="color:#4ade80">✓</span> Stack started — all services healthy</div>
                <div class="mt-2 pt-2" style="border-top:1px solid var(--border)">
                  <span style="color:#a78bfa">Console</span> → <span style="color:var(--text)">http://console.clinic.local</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Services ──────────────────────────────────────────────────── -->
    <section class="py-24 px-5 border-t" style="border-color:var(--border)">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:var(--accent)">Platform services</p>
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color:var(--text)">Everything your app needs. Built in.</h2>
          <p class="mt-3 text-base max-w-xl mx-auto" style="color:var(--text-muted)">Five services, one installation. Shared across every app on your network.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

          <!-- Gateway -->
          <a href={`${base}docs/services/gateway`} class="service-card group p-5 rounded-xl border transition-all duration-200"
             style="border-color:var(--border);background:var(--surface)">
            <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background:var(--surface-raised)">
              <img src={`${base}icon.svg`} class="w-6 h-auto" alt="Gateway" />
            </div>
            <h3 class="font-semibold text-sm mb-1.5 flex items-center gap-2" style="color:var(--text)">
              Gateway
            </h3>
            <p class="text-xs leading-relaxed" style="color:var(--text-muted)">
              The only LAN-exposed service. Validates API keys, signs internal requests with HMAC, and routes traffic to every service.
            </p>
          </a>

          <!-- Orbit -->
          <a href={`${base}docs/services/deploy`} class="service-card group p-5 rounded-xl border transition-all duration-200"
             style="border-color:var(--border);background:var(--surface)">
            <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background:var(--surface-raised)">
              <img src={`${base}services/orbit.svg`} class="w-6 h-auto" alt="Orbit" />
            </div>
            <h3 class="font-semibold text-sm mb-1.5 flex items-center gap-2" style="color:var(--text)">
              Orbit
              <span class="text-xs px-1.5 py-0.5 rounded font-medium" style="background:rgba(5,150,105,0.12);color:#059669">Live</span>
            </h3>
            <p class="text-xs leading-relaxed" style="color:var(--text-muted)">
              Frontend deploy service. Run <code style="background:var(--surface-raised);padding:1px 4px;border-radius:3px;font-size:11px">nuble deploy</code> and your SPA is live at <code style="background:var(--surface-raised);padding:1px 4px;border-radius:3px;font-size:11px">app.org.local</code> in seconds.
            </p>
          </a>

          <!-- Blaze -->
          <a href={`${base}docs/services/database`} class="service-card group p-5 rounded-xl border transition-all duration-200"
             style="border-color:var(--border);background:var(--surface)">
            <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background:var(--surface-raised)">
              <img src={`${base}services/blaze.svg`} class="w-6 h-auto" alt="Blaze" />
            </div>
            <h3 class="font-semibold text-sm mb-1.5 flex items-center gap-2" style="color:var(--text)">
              Blaze
            </h3>
            <p class="text-xs leading-relaxed" style="color:var(--text-muted)">
              Multi-tenant database backed by Postgres. Row-Level Security enforced at the database layer — one app cannot read another's rows.
            </p>
          </a>

          <!-- Identity -->
          <a href={`${base}docs/services/auth`} class="service-card group p-5 rounded-xl border transition-all duration-200"
             style="border-color:var(--border);background:var(--surface)">
            <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background:var(--surface-raised)">
              <img src={`${base}services/identity.svg`} class="w-6 h-auto" alt="Identity" />
            </div>
            <h3 class="font-semibold text-sm mb-1.5 flex items-center gap-2" style="color:var(--text)">
              Identity
              <span class="text-xs px-1.5 py-0.5 rounded font-medium" style="background:rgba(217,119,6,0.12);color:#d97706">Soon</span>
            </h3>
            <p class="text-xs leading-relaxed" style="color:var(--text-muted)">
              Auth service — sessions, API key management, and SSO across all <code style="background:var(--surface-raised);padding:1px 4px;border-radius:3px;font-size:11px">*.org.local</code> subdomains.
            </p>
          </a>

          <!-- Vault -->
          <a href={`${base}docs/services/storage`} class="service-card group p-5 rounded-xl border transition-all duration-200"
             style="border-color:var(--border);background:var(--surface)">
            <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background:var(--surface-raised)">
              <img src={`${base}services/vault.svg`} class="w-6 h-auto" alt="Vault" />
            </div>
            <h3 class="font-semibold text-sm mb-1.5 flex items-center gap-2" style="color:var(--text)">
              Vault
              <span class="text-xs px-1.5 py-0.5 rounded font-medium" style="background:rgba(217,119,6,0.12);color:#d97706">Soon</span>
            </h3>
            <p class="text-xs leading-relaxed" style="color:var(--text-muted)">
              File storage service. Upload and serve files from a private, local filesystem volume. No S3 accounts, no egress fees.
            </p>
          </a>

          <!-- Console -->
          <a href={`${base}docs/getting-started/quick-start`} class="service-card group p-5 rounded-xl border transition-all duration-200"
             style="border-color:var(--border);background:var(--surface)">
            <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background:var(--surface-raised)">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.75">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/>
              </svg>
            </div>
            <h3 class="font-semibold text-sm mb-1.5" style="color:var(--text)">Console</h3>
            <p class="text-xs leading-relaxed" style="color:var(--text-muted)">
              Admin dashboard. Create apps, manage API keys, invite admins, and monitor service health — all from one UI.
            </p>
          </a>

        </div>
      </div>
    </section>

    <!-- ── How it works ───────────────────────────────────────────────── -->
    <section class="py-24 px-5 border-t" style="border-color:var(--border);background:var(--surface)">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:var(--accent)">Zero to deployed</p>
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color:var(--text)">Up and running in three steps.</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

          <!-- Step 1 -->
          <div class="step-card p-6 rounded-xl border" style="border-color:var(--border);background:var(--bg)">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white flex-shrink-0" style="background:var(--accent)">1</div>
              <h3 class="font-semibold text-sm" style="color:var(--text)">Install on any Linux machine</h3>
            </div>
            <div class="font-mono text-xs p-3.5 rounded-lg" style="background:var(--code-bg);color:var(--text-muted)">
              <span style="color:#a78bfa">$</span> curl -sSL .../install.sh | bash<br/>
              <br/>
              <span style="color:#6b7280"># Prompts you for:</span><br/>
              <span style="color:#4ade80">?</span> Org name: <span style="color:var(--text)">clinic</span><br/>
              <span style="color:#4ade80">?</span> Admin email: <span style="color:var(--text)">admin@clinic.com</span><br/>
              <span style="color:#4ade80">?</span> Admin password: <span style="color:var(--text)">••••••••</span>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="step-card p-6 rounded-xl border" style="border-color:var(--border);background:var(--bg)">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white flex-shrink-0" style="background:var(--accent)">2</div>
              <h3 class="font-semibold text-sm" style="color:var(--text)">Create an app in the Console</h3>
            </div>
            <div class="font-mono text-xs p-3.5 rounded-lg" style="background:var(--code-bg);color:var(--text-muted)">
              <span style="color:#6b7280"># Install the CLI</span><br/>
              <span style="color:#a78bfa">$</span> npm install -g @nublestation/cli<br/>
              <br/>
              <span style="color:#6b7280"># Link your project</span><br/>
              <span style="color:#a78bfa">$</span> nuble init \<br/>
              &nbsp;&nbsp;--url http://api.clinic.local \<br/>
              &nbsp;&nbsp;--slug tasks \<br/>
              &nbsp;&nbsp;--key nbl_••••••••
            </div>
          </div>

          <!-- Step 3 -->
          <div class="step-card p-6 rounded-xl border" style="border-color:var(--border);background:var(--bg)">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white flex-shrink-0" style="background:var(--accent)">3</div>
              <h3 class="font-semibold text-sm" style="color:var(--text)">Deploy your frontend</h3>
            </div>
            <div class="font-mono text-xs p-3.5 rounded-lg" style="background:var(--code-bg);color:var(--text-muted)">
              <span style="color:#a78bfa">$</span> npm run build<br/>
              <span style="color:#a78bfa">$</span> nuble deploy<br/>
              <br/>
              <span style="color:#4ade80">✓</span> Uploaded 847 KB<br/>
              <span style="color:#4ade80">✓</span> Live at <span style="color:var(--text)">http://tasks.clinic.local</span>
            </div>
          </div>

        </div>

        <div class="mt-10 text-center">
          <a href={`${base}docs/getting-started/installation`}
             class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
             style="color:var(--accent)"
             onmouseover="this.style.color='var(--accent-hover)'"
             onmouseout="this.style.color='var(--accent)'">
            Full installation guide
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Why NubleStation ───────────────────────────────────────────── -->
    <section class="py-24 px-5 border-t" style="border-color:var(--border)">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:var(--accent)">The problem</p>
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color:var(--text)">Why clinics can't use the cloud.</h2>
          <p class="mt-3 text-base max-w-2xl mx-auto" style="color:var(--text-muted)">Patient data cannot leave the premises. Most BaaS platforms are cloud-only. NubleStation fills that gap.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
          <div class="p-5 rounded-xl border" style="border-color:var(--border);background:var(--surface)">
            <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#dc2626">Existing options — why they fail</p>
            <div class="space-y-3">
              {[
                ['Firebase / Supabase Cloud', 'Patient data cannot leave premises (compliance)'],
                ['Self-hosted Supabase / Appwrite', 'Requires DevOps expertise the clinic does not have'],
                ['PocketBase / single-binary tools', 'No multi-app isolation, no LAN-native networking'],
                ['Custom servers per app', 'Heavy footprint, no shared services, no SSO'],
              ].map(([name, reason]) => (
                <div class="flex gap-3">
                  <span class="mt-0.5 flex-shrink-0 text-xs" style="color:#dc2626">✕</span>
                  <div>
                    <p class="text-xs font-semibold mb-0.5" style="color:var(--text)">{name}</p>
                    <p class="text-xs" style="color:var(--text-muted)">{reason}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="p-5 rounded-xl border" style="border-color:rgba(109,40,217,0.3);background:rgba(109,40,217,0.04)">
            <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:var(--accent)">NubleStation — what we offer</p>
            <div class="space-y-3">
              {[
                ['One-command install', 'curl | bash. No YAML, no DevOps knowledge needed.'],
                ['LAN-native networking', 'CoreDNS + Caddy serve every subdomain on your network.'],
                ['Enforced app isolation', 'Postgres RLS means one app cannot read another\'s data.'],
                ['Offline by design', 'No internet dependency at runtime. Unplug the cable — everything keeps working.'],
              ].map(([name, reason]) => (
                <div class="flex gap-3">
                  <span class="mt-0.5 flex-shrink-0 text-xs" style="color:#059669">✓</span>
                  <div>
                    <p class="text-xs font-semibold mb-0.5" style="color:var(--text)">{name}</p>
                    <p class="text-xs" style="color:var(--text-muted)">{reason}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="text-center">
          <a href={`${base}docs/getting-started/introduction`}
             class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
             style="color:var(--accent)"
             onmouseover="this.style.color='var(--accent-hover)'"
