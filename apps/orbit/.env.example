DATABASE_URL=postgres://nuble:nuble@localhost:5432/nuble_dev
INTERNAL_HMAC_SECRET=dev-secret-not-for-prod-must-be-min-16
STORAGE_ROOT=/tmp/nuble-dev-apps
PORT=3002

# dev: debug (verbose — HMAC details, timing, all requests including health)
# staging: info  (deploys, auth failures, errors — health checks filtered)
# production: warn (errors and security events only)
LOG_LEVEL=debug

# dev | production  (staging runs with NODE_ENV=production + LOG_LEVEL=info)
NODE_ENV=development
