{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NUBLE_ENV_FILE", "ORBIT_URL", "TEST_APP_ID", "TEST_USER_ID", "TEST_APP_SLUG",
    "PLATFORM_DB_URL", "ORG_NAME", "ORG_DOMAIN", "HOST_IP",
    "INTERNAL_HMAC_SECRET", "SECURE_COOKIES"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": ["DATABASE_URL", "DATABASE_URL_TEST", "INTERNAL_HMAC_SECRET", "NODE_ENV", "STORAGE_ROOT"]
    },
    "migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    }
  }
}
