{
  "name": "@nublestation/client",
  "version": "0.1.0",
  "description": "NubleStation unified client — one import for all services",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build":       "tsc -p tsconfig.build.json",
    "dev":         "tsc -p tsconfig.build.json --watch",
    "test":        "vitest run",
    "test:watch":  "vitest",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@nublestation/vault": "workspace:*"
  },
  "devDependencies": {
    "@nublestation/typescript-config": "workspace:*",
    "@types/node": "^22.10.1",
    "typescript": "5.9.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
