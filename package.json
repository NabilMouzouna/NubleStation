{
  "name": "NubleStation",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:dev": "pnpm --filter @nublestation/db dev",
    "db:migrate": "pnpm --filter @nublestation/db migrate",
    "db:test": "pnpm --filter @nublestation/db test",
    "db:generate": "pnpm --filter @nublestation/db generate",
    "gateway:dev": "pnpm --filter @nublestation/gateway dev",
    "gateway:test": "pnpm --filter @nublestation/gateway test",
    "docs:dev": "pnpm --filter @nublestation/docs dev",
    "docs:build": "pnpm --filter @nublestation/docs build"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.8",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
