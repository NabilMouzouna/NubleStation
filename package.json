{
  "name": "NubleStation",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "blaze:dev": "pnpm --filter @nublestation/blaze dev",
    "blaze:migrate": "pnpm --filter @nublestation/blaze migrate",
    "blaze:test": "pnpm --filter @nublestation/blaze test",
    "blaze:generate": "pnpm --filter @nublestation/blaze generate",
    "gateway:dev": "pnpm --filter @nublestation/gateway dev",
    "gateway:test": "pnpm --filter @nublestation/gateway test",
    "console:dev": "pnpm --filter @nublestation/console dev",
    "console:build": "pnpm --filter @nublestation/console build",
    "orbit:dev": "pnpm --filter @nublestation/orbit dev",
    "cli:dev": "pnpm --filter @nublestation/cli dev",
    "cli:test": "pnpm --filter @nublestation/cli test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.8",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
